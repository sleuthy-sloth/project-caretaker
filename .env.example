# === REQUIRED: FIREBASE CONFIGURATION ===
# Project Caretaker uses Firebase for authentication (Google sign-in)
# and Firestore (persistent game state).
#
# To set up:
# 1. Go to https://console.firebase.google.com and create a project.
# 2. Enable Authentication → Sign-in method → Google.
# 3. Enable Firestore Database (start in test mode, then configure rules).
# 4. Create a web app in Project Settings → General → Your apps.
# 5. Copy the apiKey, projectId, authDomain, etc. into a .env file:
#
#   VITE_FIREBASE_API_KEY=AIzaSy...
#   VITE_FIREBASE_PROJECT_ID=my-project-12345
#   VITE_FIREBASE_AUTH_DOMAIN=my-project.firebaseapp.com
#   VITE_FIREBASE_APP_ID=1:123:web:abc
#
# The .env file is already in .gitignore — your keys stay local.

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""

# === REQUIRED (at least one): CLOUD AI PROVIDERS ===
# The server rotates through all configured providers in a round-robin
# pattern (starting offset = timestamp % N) to avoid exhausting any
# single provider's daily free credits. Each request tries every provider
# in sequence, then makes one additional pass (max 5 attempts total).
# If all providers fail, a built-in fallback narrative is served.
# Configure as many as you have keys for — more providers = more reliability.

# Google Gemini (gemini-2.5-flash)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# OpenRouter (routes to various free models)
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=""

# Groq (llama-3.3-70b-versatile)
# https://console.groq.com/keys
GROQ_API_KEY=""

# Mistral (open-mistral-nemo — generous free tier)
# https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=""

# === OPTIONAL: APP ===
# APP_URL="https://your-app-url.com"
