# === FIREBASE ===
# Firebase config lives in firebase-applet-config.json.
# Override any value at runtime by setting the corresponding env var below.
# VITE_FIREBASE_API_KEY="your-api-key"
# VITE_FIREBASE_PROJECT_ID="your-project-id"
# VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
# VITE_FIRESTORE_DATABASE_ID="your-database-id"

# === GEMINI (NOT USED with local WebLLM, but available for fallback) ===
# GEMINI_API_KEY="your-gemini-api-key"

# === APP ===
# APP_URL="https://your-app-url.com"
